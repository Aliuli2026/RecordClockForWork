<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gradient_start"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ 上班打卡"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="工作满9小时自动提醒下班"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- 当前时间卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            card_view:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前时间：--:--:--"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 打卡信息卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            card_view:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_clock_in_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="打卡时间：未打卡"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_off_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下班时间：--"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 倒计时卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            card_view:cardBackgroundColor="@color/accent_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_count_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="等待打卡..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 状态提示 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ 请点击打卡按钮记录上班时间"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 打卡按钮 -->
        <Button
            android:id="@+id/btn_clock_in"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="立即打卡"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp" />

        <!-- 取消闹钟按钮 -->
        <Button
            android:id="@+id/btn_cancel_alarm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="取消下班提醒"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:backgroundTint="@color/card_bg"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- 说明文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 打卡后自动计算工作9小时，时间到了会震动提醒并弹出通知"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
